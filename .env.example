# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=development
PORT=5001

# ==========================================
# Database (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/auth_project
DB_USER=user
DB_PASSWORD=password
DB_NAME=auth_project

# ==========================================
# Redis
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ==========================================
# JWT Configuration
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m

# ==========================================
# Cookie Configuration
# ==========================================
COOKIE_SECRET=your-cookie-secret-key-change-this-in-production

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==========================================
# Email Configuration
# ==========================================
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=no-reply@yourdomain.com
RESEND_FROM_NAME=Auth Project

# ==========================================
# Application Settings
# ==========================================
# Rate limiting values (requests per window)
AUTH_RATE_LIMIT_WINDOW=3600
AUTH_RATE_LIMIT_MAX=10

# IP ban duration (seconds)
IP_BAN_DURATION=86400

# Grace period for token refresh (milliseconds)
GRACE_PERIOD=30000
